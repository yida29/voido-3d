{
  "name": "voido-webgl",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "voido (千葉県南房総の合宿施設) の WebGL 3D 見取り図ビューワー",
  "scripts": {
    "ifc": "tsx tools/build-ifc.ts",
    "copy-wasm": "node -e \"import('node:fs').then(fs=>{fs.cpSync('node_modules/web-ifc/web-ifc.wasm','public/web-ifc.wasm');fs.cpSync('node_modules/web-ifc/web-ifc-mt.wasm','public/web-ifc-mt.wasm');})\"",
    "predev": "npm run copy-wasm && npm run ifc",
    "prebuild": "npm run copy-wasm && npm run ifc",
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "three": "^0.169.0",
    "web-ifc": "^0.0.77"
  },
  "devDependencies": {
    "@types/three": "^0.169.0",
    "playwright": "^1.59.1",
    "pngjs": "^7.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
